# ARMLS Spark API credentials
# Get these from your ARMLS/FlexMLS Spark API account at https://sparkplatform.com
SPARK_API_KEY=your_spark_api_key_here
SPARK_BASE_URL=https://sparkapi.com/v1

# Server configuration
PORT=3000

# CORS allowed origins (comma-separated)
# Set to your Claude.ai Team URL in production
# Leave empty to allow all origins (development only)
ALLOWED_ORIGINS=https://claude.ai
